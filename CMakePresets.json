{
    "version": 3,
    "configurePresets": [
        {
            "name": "stm32f4_debug",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/arm-none-eabi.cmake",
                "CMAKE_BUILD_TYPE": "Debug",

                "DRONE_C_FLAGS": "-ffreestanding",
                "DRONE_CXX_FLAGS": "-fno-rtti -fno-exceptions",
                "DRONE_EXE_LINKER_FLAGS": "-nostdlib",
                "DRONE_LINKER_FILE_PATH": "${sourceDir}/linker/STM32F446RETx_FLASH.ld",

                "COCO_PLATFORM": "stm32f446"
            }
        },
        {
            "name": "stm32f4_release",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/arm-none-eabi.cmake",
                "CMAKE_BUILD_TYPE": "Release",

                "DRONE_C_FLAGS": "-ffreestanding",
                "DRONE_CXX_FLAGS": "-fno-rtti -fno-exceptions",
                "DRONE_EXE_LINKER_FLAGS": "-nostdlib",
                "DRONE_LINKER_FILE_PATH": "${sourceDir}/linker/STM32F446RETx_FLASH.ld",

                "COCO_PLATFORM": "stm32f446"
            }
        },
        {
            "name": "linux_debug",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",

                "COCO_PLATFORM": "linux"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "stm32f4_debug",
            "configurePreset": "stm32f4_debug"
        },
        {
            "name": "stm32f4_release",
            "configurePreset": "stm32f4_release"
        },
        {
            "name": "linux_debug",
            "configurePreset": "linux_debug"
        }
    ]
}
